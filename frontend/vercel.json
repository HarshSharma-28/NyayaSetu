{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["bom1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "@nyayasetu_api_url",
    "NEXT_PUBLIC_SUPABASE_URL": "@nyayasetu_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@nyayasetu_supabase_key"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' data: blob:; script-src 'self' 'unsafe-eval' 'unsafe-inline'"
        }
      ]
    }
  ]
}
