FROM python:3.11-slim

WORKDIR /app

# System dependencies for OpenCV, Tesseract OCR, and PDF processing
RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    tesseract-ocr \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Set environment variables (replace with your actual values, or use Cloud Run env vars)
ENV SUPABASE_URL=https://<your-project>.supabase.co/
ENV SUPABASE_SERVICE_KEY=<your-service-role-key>
ENV SUPABASE_ANON_KEY=<your-anon-key>
ENV JWT_SECRET=<your-jwt-secret>
ENV JWT_ALGORITHM=HS256
ENV JWT_EXPIRE_MINUTES=480
ENV DEMO_MODE=true
ENV ENVIRONMENT=production
ENV GEMINI_API_KEY=<your-gemini-api-key>
ENV CORS_ORIGINS='["https://your-frontend.vercel.app","http://localhost:3000"]'

# Cloud Run injects $PORT at runtime (default 8080)
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080}"]
